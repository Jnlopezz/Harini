; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Popuchio-tutorials-with-julie"
run/main_scene="res://game/rooms/livingroom/room_livingroom.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

Globals="*uid://cbfyhkvptty6h"
Cursor="*uid://c2pqh7ajiuiy0"
E="*uid://rda8wggldt5o"
R="*uid://csu6qrs751quu"
C="*uid://cs1cm0ra58kfb"
I="*uid://qptajhi3o0hl"
D="*uid://dsebmg2q2hogo"
A="*uid://c2p774qpxrg3t"
G="*uid://3uvkbonimhxt"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/window_width_override=960
window/size/window_height_override=540
window/stretch/mode="viewport"

[editor_plugins]

enabled=PackedStringArray("res://addons/popochiu/editor/gizmos/plugin.cfg", "res://addons/popochiu/plugin.cfg")

[input]

popochiu-interact={
